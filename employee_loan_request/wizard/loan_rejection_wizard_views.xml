<odoo>

    <record id="rejection_wizard_view_form" model="ir.ui.view">
        <field name="name">rejection_wizard.view.form</field>
        <field name="model">loan.rejection.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="loan_id" invisible="1"/>
                    <field name="rejetion_reason" />
                </group>
                <footer>
                    <button string="Confirm" name="accept_the_reason" type="object"
                        class="btn-primary" />
                    <button string="Cancel" special="cancel" class="btn-secondary" />
                </footer>
            </form>
        </field>
    </record>

    <record id="rejection_action" model="ir.actions.act_window">
        <field name="name">Reject Reason</field>
        <field name="res_model">loan.rejection.wizard</field>
        <field name="target">new</field>
        <field name="view_mode">form</field>
    </record>

</odoo>