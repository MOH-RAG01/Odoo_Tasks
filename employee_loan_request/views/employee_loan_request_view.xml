<odoo>
    <record id="loans_view_tree" model="ir.ui.view">
        <field name="name">loans.view.tree</field>
        <field name="model">employee.loan.request</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="employee_id" />
                <field name="loan_amount" />
                <field name="state" />
                <field name="number_of_installments" optional="1" />
                <field name="installment_amount_per_month" optional="1" />
                <field name="request_date" optional="1" />
                <field name="start_date" optional="1" />
                <field name="loan_justification" optional="1" />
            </tree>
        </field>
    </record>

    <record id="loan_view_search" model="ir.ui.view">
        <field name="name">loan.view.search</field>
        <field name="model">employee.loan.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <field name="employee_id" />
            </search>
        </field>
    </record>

    <record id="loan_view_form" model="ir.ui.view">
        <field name="name">loan.view.form</field>
        <field name="model">employee.loan.request</field>
        <field name="arch" type="xml">
            <form>

                <header>
                    <field name="state" widget="statusbar" />

                    <button string="Draft" name="set_state_draft" type="object" class="oe_highlight"
                        invisible="state not in [False,'submitted'] " />

                    <button string="Submit" name="set_state_submitted" type="object"
                        class="oe_highlight" invisible="state not in [False,'draft']" />

                    <button string="Approve" name="set_state_approved" type="object"
                        class="oe_highlight" invisible="state !='submitted'" />

                    <button string="Reject" name="set_state_rejected" type="object"
                        class="oe_highlight" invisible="state !='submitted'" />

                    <button string="Complete" name="set_state_completed" type="object"
                        class="oe_highlight" invisible="state !='ongoing'" />

                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="loan_owner" string="Belongs To" type="object"
                            class="oe_stat_button" icon="fa-user" />
                    </div>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="employee_id" readonly="state not in [False,'draft']" />
                            <field name="loan_justification" readonly="state not in [False,'draft']" />


                        </group>
                        <group>
                            <field name="request_date" readonly="state not in [False,'draft']" />
                            <field name="loan_amount" readonly="state not in [False,'draft']" />
                            <field name="number_of_installments"
                                readonly="state not in [False,'draft']" />
                            <field name="installment_amount_per_month" />
                            <field name="start_date" readonly="state not in [False,'draft']" />
                        </group>
                    </group>
                    <notebook>
                        <page name="All Installments">
                            <field name="installment_line_ids" readonly="1">
                                <tree>
                                    <field name="sequence" string="Installment#" />
                                    <field name="amount" />
                                    <field name="state" />
                                    <field name="due_date" />
                                </tree>
                                <form>
                                    <group>
                                        <field name="related_loan_id" invisible="1" />
                                        <field name="sequence" />
                                        <field name="amount" />
                                        <field name="state" />
                                        <field name="due_date" />
                                    </group>

                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers" />
                    <field name="activity_ids" widget="mail_activity" />
                    <field name="message_ids" widget="mail_thread" />
                </div>
            </form>
        </field>
    </record>

    <record id="loan_payment_update_cron" model="ir.cron">
        <field name="name">Mark loan installments as paid and reconile</field>
        <field name="model_id" ref="model_employee_loan_request" />
        <field name="interval_number">1</field>
        <field name="interval_type">months</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
        <field name="state">code</field>
        <field name="code">
            model.update_loan_payment()
        </field>
    </record>

    <record id="loans_menu_action" model="ir.actions.act_window">
        <field name="name">Loan Request</field>
        <field name="res_model">employee.loan.request</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>